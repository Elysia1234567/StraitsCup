{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^wd-(.*)": "wot-design-uni/components/wd-$1/wd-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "对话列表",
        "navigationBarBackgroundColor": "#0f0824",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/chat/chat",
      "style": {
        "navigationBarTitleText": "NEURAL CHAT",
        "navigationBarBackgroundColor": "#0f0824",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/agent/agent",
      "style": {
        "navigationBarTitleText": "智能体矩阵",
        "navigationBarBackgroundColor": "#0f0824",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/gallery/gallery",
      "style": {
        "navigationBarTitleText": "非遗图鉴",
        "navigationBarBackgroundColor": "#0f0824",
        "navigationBarTextStyle": "white"
      }
    },
    {
      "path": "pages/dev-api/dev-api",
      "style": {
        "navigationBarTitleText": "接口实验室",
        "navigationBarBackgroundColor": "#0f0824",
        "navigationBarTextStyle": "white"
      }
    }
  ],
  "tabBar": {
    "color": "#7c7395",
    "selectedColor": "#c4b5fd",
    "backgroundColor": "#0f0824",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页",
        "iconPath": "static/home.png",
        "selectedIconPath": "static/home-active.png"
      },
      {
        "pagePath": "pages/chat/chat",
        "text": "对话",
        "iconPath": "static/tab-chat.png",
        "selectedIconPath": "static/tab-chat-active.png"
      },
      {
        "pagePath": "pages/agent/agent",
        "text": "智能体",
        "iconPath": "static/tab-agent.png",
        "selectedIconPath": "static/tab-agent-active.png"
      },
      {
        "pagePath": "pages/gallery/gallery",
        "text": "图鉴",
        "iconPath": "static/tab-gallery.png",
        "selectedIconPath": "static/tab-gallery-active.png"
      }
    ]
  },
  "globalStyle": {
    "navigationBarBackgroundColor": "#0f0824",
    "navigationBarTextStyle": "white",
    "navigationBarTitleText": "CYBER",
    "backgroundColor": "#06040f"
  },
  "sitemapLocation": "sitemap.json"
}
